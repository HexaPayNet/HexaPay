{
  "name": "hexapay",
  "version": "1.0.2",
  "description": "HexaPay desktop payroll and workforce client",
  "author": "HexaPay",
  "main": "main.js",
  "scripts": {
    "desktop": "electron .",
    "setup:all": "node scripts/setup-all.js",
    "setup:local": "node scripts/setup-all.js --desktop=local",
    "setup:lan": "node scripts/setup-all.js --desktop=lan",
    "config:lan": "node scripts/configure-lan-backend.js",
    "build:win-icon": "node scripts/build-windows-icon.js",
    "migrate:paye-config": "node scripts/migrate-paye-config.js",
    "package:desktop": "npm run build:win-icon && electron-builder --win nsis portable",
    "package:desktop:unpacked": "node scripts/package-windows-pilot.js",
    "package:update": "powershell -ExecutionPolicy Bypass -File scripts/build-update-package.ps1",
    "check:syntax": "node scripts/run-checks.js --syntax-only",
    "check:shared": "node scripts/run-checks.js --tests-only",
    "smoke:pilot": "node scripts/pilot-smoke.js",
    "test": "node scripts/run-checks.js",
    "release:signing:check": "node scripts/release-signing-check.js",
    "release:prep": "node scripts/release-prep.js",
    "backup:cloud": "node scripts/cloud-backup.js",
    "backup:inspect": "node scripts/inspect-cloud-backup.js",
    "ops:health": "node scripts/ops-health-check.js",
    "ops:backup:drill": "node scripts/backup-drill.js",
    "ops:readiness": "node scripts/ops-readiness.js",
    "dev": "node backend/server.js",
    "start": "node backend/server.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^26.1.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.hexapay.desktop",
    "productName": "HexaPay",
    "directories": {
      "output": "dist/electron-builder"
    },
    "files": [
      "Assets/**/*",
      "shared/**/*",
      "css/**/*",
      "js/**/*",
      "Index.html",
      "main.js",
      "preload.js",
      "splash.html",
      "splash.js",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "hexapay.desktop.env",
        "to": "hexapay.desktop.env"
      }
    ],
    "extraResources": [
      {
        "from": "hexapay.desktop.env",
        "to": "hexapay.desktop.env"
      }
    ],
    "npmRebuild": false,
    "asar": true,
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "Assets/HexaPayEMBLEM.ico",
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "HexaPay-${version}-Portable.${ext}"
    },
    "nsis": {
      "artifactName": "HexaPay-${version}-Setup.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HexaPay"
    }
  }
}
